{
  "css.validate": false,
  "scss.validate": false,
  "tailwindCSS.includeLanguages": {
    "scss": "css"
  },
  "tailwindCSS.experimental.classRegex": [
    ["clsx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
    ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "tailwindCSS.experimental.configFile": "./tailwind.config.js",
  "files.associations": {
    "*.scss": "tailwindcss"
  }
}
