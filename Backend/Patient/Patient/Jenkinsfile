pipeline {
    agent any

    tools {
        maven 'Maven-3.9'
        jdk 'Java-17'
    }

    stages {
        stage('Build & Package') {
            steps {
                dir('Backend/Patient/Patient') {
                    echo 'Building Patient Service JAR...'
                    sh 'mvn clean package -DskipTests'
                }
            }
        }
        
        stage('Dockerize') {
            steps {
                dir('Backend/Patient/Patient') {
                    echo 'Building Patient Service Docker image...'
                    sh 'docker build -t patient-service:latest .'
                }
            }
        }

        stage('SonarQube Analysis') {
            environment {
                scannerHome = tool 'SonarScanner'
            }
            steps {
                dir('Backend/Patient/Patient') {
                    withSonarQubeEnv('SonarQube') {
                        sh """
                            ${scannerHome}/bin/sonar-scanner \
                            -Dsonar.projectKey=alzheimer-care-patient \
                            -Dsonar.projectName="Patient Service" \
                            -Dsonar.sources=. \
                            -Dsonar.java.binaries=target/classes
                        """
                    }
                }
            }
        }
        stage('Deploy') {
            steps {
                script {
                    // 1. Stop and remove the old container
                    sh 'docker stop patient-service || true'
                    sh 'docker rm patient-service || true'
                    
                    // 2. Run the new one on the shared network
                    sh """
                        docker run -d --name patient-service \
                        --network alzheimer-net \
                        -p 8084:8084 \
                        -e SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/Patient \
                        -e EUREKA_SERVER_URL=http://eureka-server:8761/eureka \
                        patient-service:latest
                    """
                }
            }
        }
    }
}