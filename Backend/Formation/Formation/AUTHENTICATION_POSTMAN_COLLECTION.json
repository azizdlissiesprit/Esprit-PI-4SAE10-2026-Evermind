              ]
            },
            "description": "Récupérer les informations d'un utilisateur\n\nRôles autorisés: ADMIN (uniquement)\n\nRemplacer 1 par l'ID de l'utilisateur"
          },
          "response": []
        },
        {
          "name": "3. Deactivate User (ADMIN only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:9086/admin/users/2/deactivate",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9086",
              "path": [
                "admin",
                "users",
                "2",
                "deactivate"
              ]
            },
            "description": "Désactiver un utilisateur\n\nRôles autorisés: ADMIN (uniquement)\n\nRemplacer 2 par l'ID de l'utilisateur"
          },
          "response": []
        },
        {
          "name": "4. Activate User (ADMIN only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:9086/admin/users/2/activate",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9086",
              "path": [
                "admin",
                "users",
                "2",
                "activate"
              ]
            },
            "description": "Activer un utilisateur désactivé\n\nRôles autorisés: ADMIN (uniquement)\n\nRemplacer 2 par l'ID de l'utilisateur"
          },
          "response": []
        }
      ]
    },
    {
